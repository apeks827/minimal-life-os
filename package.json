{
  "name": "minimal-life-os",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @life/db db:generate",
    "db:migrate": "pnpm --filter @life/db db:migrate",
    "db:check": "pnpm --filter @life/db db:check"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.8.4",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.4"
  }
}
