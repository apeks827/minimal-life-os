{
  "name": "minimal-life-os",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @life/db db:generate",
    "db:migrate": "pnpm --filter @life/db db:migrate",
    "db:check": "pnpm --filter @life/db db:check",
    "seed:owner": "node scripts/seed-owner.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "turbo": "^2.9.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.2.7",
    "vitest": "^4.1.5"
  }
}
