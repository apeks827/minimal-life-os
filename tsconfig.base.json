{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@life/shared": ["packages/shared/src/index.ts"],
      "@life/ai": ["packages/ai/src/index.ts"],
      "@life/db": ["packages/db/src/index.ts"],
      "@life/ui": ["packages/ui/src/index.ts"]
    }
  }
}
